APP_ENV=prod
APP_SECRET=change_me_random_32_chars
APP_SHARE_DIR=var/share

DATABASE_URL="mysql://user:password@host:3306/dbname?serverVersion=8.0&charset=utf8mb4"

CORS_ALLOW_ORIGIN='^https?://your-frontend.vercel.app$'
JWT_TTL=3600

FRONTEND_URL=https://your-frontend.vercel.app

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_random_passphrase
